/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

MENU_1 MENU DISCARDABLE 
BEGIN
    POPUP "&Flights"
    BEGIN
        MENUITEM SEPARATOR
        MENUITEM "&Custom Mission ...",         CM_FLIGHTCUSTM
        MENUITEM SEPARATOR
        MENUITEM "&New Game",                   CM_NEWGAME
        MENUITEM "E&xit",                       CM_EXIT
    END
    POPUP "&Demos"
    BEGIN
        MENUITEM "&Furball",                    CM_DEMFURBALL
        MENUITEM "&Melee",                      CM_DEMOSMELEE
        MENUITEM "&Pistons",                    CM_DEMOPVY
        MENUITEM "F&84Scrap",                   CM_DEMOSFSCRAP
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&0 Virtual",                  CM_VIEW_VIRTUAL
        MENUITEM "&1 Front",                    CM_VIEW_FRONT
        MENUITEM "&2 Left",                     CM_VIEW_LEFT
        MENUITEM "&3 Right",                    CM_VIEW_RIGHT
        MENUITEM "&4 Back",                     CM_VIEW_BACK
        MENUITEM "&5 Top",                      CM_VIEW_TOP
        MENUITEM "&6 Outside",                  CM_VIEW_OUTSIDE
        MENUITEM "&7 Track",                    CM_VIEW_COMBAT_TRACK
        MENUITEM "&& Padlock",                  CM_VIEW_PADLOCK
        MENUITEM "&8 Target Track",             CM_VIEW_COMBAT_TRACK_II
        MENUITEM "&9 FlyBy",                    CM_VIEW_FLYBY
    END
    POPUP "&Controls"
    BEGIN
        MENUITEM "&B Speed Brakes",             CM_CONTROLSBRAKES
        MENUITEM "&W Wheel Brakes",             CM_CONTROLWBRAKES
        MENUITEM "&G Landing Gear",             CM_CONTROLS_GEAR
        MENUITEM "&* Full Throttle",            CM_CONTROLS_FULL_THROTTLE
        MENUITEM "&/ Cut Throttle",             CM_CONTROLS0THROTTLE
        MENUITEM "&X Arm Weapon",               CM_SABREGUNS
        MENUITEM "Next Weapon",                 CM_NEXT_WEAPON
        MENUITEM "&A Autopilot",                CM_SABREAUTO
        MENUITEM "&Pause",                      CM_SABREP_PAUSE
        MENUITEM "Next Aircraft",               CM_SABRENEXT_AIRCRAFT
    END
    POPUP "&Options"
    BEGIN
        MENUITEM "&C Cockpit",                  CM_SABREC_COCKPIT
        MENUITEM "&H Hud",                      CM_HUD
        MENUITEM "&V Flight Path",              CM_FLIGHTPATH
        MENUITEM "&S Airframe",                 CM_AIRFRAME
        MENUITEM "Clouds",                      CM_SCNCLOUDS
        MENUITEM "Terrain",                     CM_SCNTRRN
        MENUITEM "Sound",                       CM_SOUND
        MENUITEM SEPARATOR
        MENUITEM "Control Devices ...",         CM_DEVICES
    END
    POPUP "Help"
    BEGIN
        MENUITEM "&Help",                       CM_SABRE_HELP
        MENUITEM "&About SABRE",                CM_ABOUT_SABRE
        MENUITEM "Textures",                    CM_TEXTURES
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

ABOUT_DLG DIALOGEX 91, 69, 269, 175
STYLE WS_POPUP | WS_VISIBLE | WS_CAPTION
CAPTION "About SABRE"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,115,121,38,13
    LTEXT           "",IDSTATIC_VERSION,0,123,110,11,0,WS_EX_TRANSPARENT
    CTEXT           "Contributions by:  Karl Larocca  Antti Barck  David Mansfield  Pierre de Mouveaux\n Web Site Hosted by: Communication Billing Technologies\nUnsolicited Comments by: My Father",
                    IDSTATIC_CREDITS,0,150,269,26
END

MISSION_DLG DIALOG DISCARDABLE  29, 48, 207, 111
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "SABRE Custom Mission"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,148,6,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,148,24,50,14
    EDITTEXT        IDC_EDIT1,11,25,118,12
    LTEXT           "Flight File",-1,11,10,115,8
    CONTROL         "Randomize Positions",IDC_RADIOBUTTON1,"Button",
                    BS_AUTOCHECKBOX,11,80,83,12
    EDITTEXT        IDC_EDIT2,11,60,118,12
    LTEXT           "Ground Unit File",-1,11,45,115,8
    CONTROL         "Demo Mode",IDC_RADIOBUTTON2,"Button",BS_AUTOCHECKBOX,97,
                    81,95,12
END

FLTCNTRL_DLG DIALOG DISCARDABLE  0, 0, 275, 103
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "Flight Controls"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,84,76,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,142,76,50,14
    RADIOBUTTON     "Joystick",IDC_YDJOY,15,22,60,10,WS_TABSTOP
    RADIOBUTTON     "Mouse",IDC_YDMOU,15,37,55,10,WS_TABSTOP
    RADIOBUTTON     "Keyboard",IDC_YDKEY,15,52,64,10,WS_TABSTOP
    GROUPBOX        "Yoke Device",IDC_STATIC,7,6,86,64
    RADIOBUTTON     "Rudder Pedals",IDC_RDJOY,188,22,60,10,WS_TABSTOP
    RADIOBUTTON     "Keyboard",IDC_RDKEY,188,37,55,10,WS_TABSTOP
    GROUPBOX        "Rudder Device",IDC_STATIC,180,6,86,64
    RADIOBUTTON     "Throttle Wheel",IDC_TDJOY,102,22,60,10,WS_TABSTOP
    RADIOBUTTON     "Keyboard",IDC_TDKEY,102,37,55,10,WS_TABSTOP
    GROUPBOX        "Throttle Device",IDC_STATIC,94,6,86,64
END

TEXTURES_DLG DIALOG DISCARDABLE  91, 69, 211, 156
STYLE WS_POPUP | WS_VISIBLE | WS_CAPTION
CAPTION "Textures View"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "Done",IDOK,150,140,38,13
    PUSHBUTTON      "Next",IDC_TXTR_NEXT,24,140,38,13
    PUSHBUTTON      "Prev",IDC_TXTR_PREV,65,140,38,13
    PUSHBUTTON      "To BMP",IDC_TXTR_FILE,106,140,38,13
    LTEXT           "",IDC_TXTR_INFO,25,119,162,12,WS_BORDER
END


